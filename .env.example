# CNO Water Data Hub — Environment Variables
# Copy this file to .env.local and fill in the values

# === Database (Railway or Supabase PostgreSQL with PostGIS) ===
# DATABASE_URL=postgresql://user:password@host:5432/waterhub
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=waterhub
# DB_USER=postgres
# DB_PASSWORD=

# === USGS API (no key required for public endpoints) ===
# USGS_BASE_URL=https://waterservices.usgs.gov/nwis

# === App ===
# NEXT_PUBLIC_APP_URL=https://waterhub.vercel.app
